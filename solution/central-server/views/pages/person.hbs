{{! person.hbs }}
<link rel="stylesheet" href="/stylesheets/movie-row.css">
<link rel="stylesheet" href="/stylesheets/movie-card.css">
<link rel="stylesheet" href="/stylesheets/oscar-section.css">

<!-- Person Name -->
<h1 class="display-4 text-white">{{name}}</h1>

<!-- Oscar Awards Section -->
{{#if oscars}}
    <section class="oscar-awards-section mb-5">
        <div class="row">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="text-white">Oscar Awards</h2>
                    <button id="toggle-oscars" class="btn btn-secondary text-warning fw-bold">
                        Show More <i class="bi bi-chevron-down"></i>
                    </button>
                </div>
                <div class="list-group" id="oscars-container">
                    {{#each oscars}}
                        <div class="list-group-item justify-content-between align-items-center oscar-item">
                            <div class="oscar-info">
                                <h5 class="mb-1">{{category}}</h5>
                                {{#if winner}}
                                    <p class="mb-1">Awarded in: {{this.year_ceremony}}</p>
                                {{else}}
                                    <p class="mb-1">Nominated in: {{this.year_ceremony}}</p>
                                {{/if}}
                            </div>
                            <div>
                                {{#if winner}}
                                    <i class="bi bi-award-fill oscar-icon" title="Oscar Winner"></i>
                                {{else}}
                                    <i class="bi bi-award oscar-icon" title="Oscar Nominee"></i>
                                {{/if}}
                            </div>
                        </div>
                    {{/each}}
                </div>
            </div>
        </div>
    </section>
{{/if}}

<!-- Related Movies -->
{{#if movies }}
    {{> movie-row category=movies.category movies=movies.movies}}
{{/if}}

<script src="/javascripts/person.js"></script>
<script src="/javascripts/movie-row.js"></script>